# Sao chép file này thành .env.local để chạy local
# Khi deploy Vercel, set biến này trong Vercel Dashboard > Settings > Environment Variables

# URL của backend API (Railway khi deploy production)
VITE_API_BASE_URL=http://localhost:8080/api

# Cấu hình Cloudinary để tải ảnh lên (tạo tài khoản free và upload preset không cần mật khẩu)
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=PetHome
